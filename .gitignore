# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local          # secrets locaux — ne jamais commiter
!.env.development   # URL dev — pas de secrets, commité
!.env.production    # URL prod — pas de secrets, commité

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# Ignorer tous les fichiers Markdown
*.md
# Sauf README.md
!README.md